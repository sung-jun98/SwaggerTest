<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.swagger.dao.CategoryDAO">
    <insert id="insertUser" parameterType="com.example.swagger.dto.UserDTO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (email, password, created_at, created_by)
        VALUES (#{email}, #{password}, NOW(), #{createdBy})
    </insert>
</mapper>